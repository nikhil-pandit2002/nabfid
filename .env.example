# Copy this file to ".env" and fill in real values. NEVER commit .env.
# The real .env is gitignored.

# Gemini (Google AI Studio) — free Flash tier. Key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-key-here

# Anthropic (Claude) — paid API. Key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-key-here

# The LLM adapter is swappable via these two lines (no code change):
#   LLM_PROVIDER=gemini     LLM_MODEL=gemini-2.5-flash  (or gemini-2.5-flash-lite)
#   LLM_PROVIDER=anthropic  LLM_MODEL=claude-haiku-4-5  (or claude-sonnet-5 / claude-opus-4-8)
# On-premise later: LLM_PROVIDER=ollama (add an Ollama backend to llm.py).
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# Prototype access gate (shared code)
ACCESS_CODE=nabfid-demo
